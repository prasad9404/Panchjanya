rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    // Check if the request is from an authenticated admin (via custom claim)
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Check if the request is from a super admin (via custom claim)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.superAdmin == true;
    }

    // Check if the request is from the document's owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }



    // ─── Public Collections (Public Read, Admin Write) ────────────────────────

    match /temples/{id} {
      allow read: if true;
      allow write: if isAdmin();

      match /architecture_hotspots/{hotspotId} {
        allow read: if true;
        allow write: if isAdmin();
      }
      match /present_hotspots/{hotspotId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /architectural_archives/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /architecture_entries/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sthan_types/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /yatraPlaces/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── User Data Security ───────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if request.auth != null;

      allow create:
        if request.auth != null &&
        request.auth.uid == userId;

      allow update:
        if (request.auth != null && request.auth.uid == userId) || isAdmin();

      allow delete: if isAdmin();

      // Subcollection for saved temples
      match /savedTemples/{templeId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
    }

    // ─── Default Deny ─────────────────────────────────────────────────────────
    // All other collections: admin-only
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
