rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    // Check if the request is from an authenticated admin (via custom claim)
    function isAdmin(req) {
      return req.auth != null && req.auth.token.admin == true;
    }

    // Check if the request is from a super admin (via custom claim)
    function isSuperAdmin(req) {
      return req.auth != null && req.auth.token.superAdmin == true;
    }

    // Check if user has admin role in their document
    function hasAdminRole(req) {
      let userDoc = get(/databases/$(database)/documents/users/$(req.auth.uid));
      return userDoc != null && (userDoc.data.role == 'admin' || userDoc.data.role == 'Admin' || userDoc.data.role == 'Super Admin');
    }

    // Check if the request is from the document's owner
    function isOwner(req, userId) {
      return req.auth != null && req.auth.uid == userId;
    }



    // ─── Public Collections (Public Read, Admin Write) ────────────────────────

    match /temples/{id} {
      allow read: if true;
      allow write: if isAdmin(request);

      match /architecture_hotspots/{hotspotId} {
        allow read: if true;
        allow write: if isAdmin(request);
      }
      match /present_hotspots/{hotspotId} {
        allow read: if true;
        allow write: if isAdmin(request);
      }
    }

    match /architectural_archives/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    match /architecture_entries/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    match /sthan_types/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    match /yatraPlaces/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // ─── Security Violations ──────────────────────────────────────────────────

    match /securityViolations/{violationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin(request) || hasAdminRole(request);
    }

    // ─── User Data Security ───────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if request.auth != null;

      allow create:
        if request.auth != null &&
        request.auth.uid == userId;

      allow update:
        if (
          request.auth != null && 
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'email', 'mobile'])
        ) || isAdmin(request) || hasAdminRole(request);

      allow delete: if isAdmin(request) || hasAdminRole(request);

      // Subcollection for saved temples
      match /savedTemples/{templeId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin(request);
      }
    }

    // ─── Default Deny ─────────────────────────────────────────────────────────
    // All other collections: admin-only
    match /{document=**} {
      allow read, write: if isAdmin(request);
    }
  }
}
